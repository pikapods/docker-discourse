#!/bin/sh
# discourse-manifest-hash — single source of truth for the plugin manifest hash.
#
# Computes a sha256 over: sorted built-in plugin names + sorted
# "<third-party-name>\t<git HEAD sha>" pairs. Used at build time to bake
# /app/baked-plugin-manifest, and at runtime by the bootstrap script to
# decide whether the bundle install + asset precompile needs to rerun.
#
# Both call sites MUST invoke this helper to avoid drift — any change to
# the hashing rules belongs here, nowhere else.
set -eu

usage() {
    cat >&2 <<EOF
Usage: discourse-manifest-hash --builtin-file <path> --third-party-file <path>

  --builtin-file PATH      File with one bundled-plugin name per line. Names
                           are sorted and folded into the hash. Pass an empty
                           file (or /dev/null) to represent "no built-in
                           plugins active".
  --third-party-file PATH  File with one "<name>\\t<git-sha>" line per active
                           third-party plugin. The bootstrap pre-resolves SHAs
                           only for plugins in the live allow-list, so dropped-
                           but-cached plugins do not poison the hash. Pass
                           /dev/null to represent "no third-party".
EOF
}

builtin_file=
third_party_file=
while [ $# -gt 0 ]; do
    case "$1" in
        --builtin-file) builtin_file=$2; shift 2 ;;
        --third-party-file) third_party_file=$2; shift 2 ;;
        -h|--help) usage; exit 0 ;;
        *) usage; exit 2 ;;
    esac
done

[ -n "$builtin_file" ] || { usage; exit 2; }
[ -n "$third_party_file" ] || { usage; exit 2; }

tmp=$(mktemp)
trap 'rm -f "$tmp"' EXIT

# Built-ins: blank lines and leading/trailing whitespace stripped, then sort -u.
if [ -f "$builtin_file" ]; then
    awk '{ gsub(/[[:space:]]/,""); if (length) print }' "$builtin_file" \
        | LC_ALL=C sort -u >> "$tmp"
fi

# Separator between the two sections so an empty builtin section and an
# empty third-party section don't collide with non-empty inputs.
printf -- '---third-party---\n' >> "$tmp"

# Third-party: skip blank lines, then sort. The caller is responsible for
# emitting only entries for currently-active plugins.
if [ -f "$third_party_file" ]; then
    awk 'NF > 0' "$third_party_file" | LC_ALL=C sort >> "$tmp"
fi

if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$tmp" | awk '{print $1}'
else
    openssl dgst -sha256 "$tmp" | awk '{print $NF}'
fi
